// Picseo — Marketplace mua bán & trao đổi ảnh online
// Schema mô hình hóa các lane trong sơ đồ luồng (Admin/Seller/Buyer/Swap/Escrow/Notif)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================ ENUMS ============================

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum SellerTier {
  NEW
  PRO
  ELITE
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum PhotoStatus {
  DRAFT // người bán đang soạn
  PENDING // chờ admin/AI duyệt (AD6)
  LIVE // đã duyệt, hiển thị (S5)
  REJECTED // bị từ chối (S5b)
  HIDDEN // người bán ẩn tạm (S7)
  LOCKED // đang trong giao dịch swap (SW3)
  DMCA_HOLD // bị khiếu nại DMCA, ẩn chờ phán quyết (AD7/S10b)
  REMOVED // gỡ bỏ (DMCA / xoá)
}

enum DmcaStatus {
  OPEN // claim mới, ảnh bị ẩn, chờ phản biện 7 ngày
  COUNTERED // người bán đã phản biện, chờ admin xét
  RESOLVED_REMOVED // admin/expiry: gỡ ảnh vĩnh viễn
  RESOLVED_RESTORED // admin bác khiếu nại: khôi phục ảnh
}

enum LicenseType {
  PERSONAL
  COMMERCIAL
  EXTENDED
  EDITORIAL
}

enum MisuseStatus {
  OPEN // báo cáo mới, chờ admin xét
  UPHELD // admin xác nhận có vi phạm phạm vi license
  REJECTED // admin bác bỏ (dùng đúng phạm vi / thiếu bằng chứng)
}

enum OrderStatus {
  PENDING // chờ thanh toán (TT1)
  PAID // thanh toán thành công (TT2 -> TT3)
  FAILED // thất bại (TT2b)
  CANCELLED
  REFUNDED
}

enum EscrowStatus {
  HELD // giữ tạm 7 ngày (TT3)
  RELEASED // đã giải ngân (TT4)
  REFUNDED // hoàn cho buyer (TT5)
  FROZEN // đóng băng do khiếu nại (TT5)
}

enum PayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

enum DisputeStatus {
  OPEN
  RESOLVED_REFUND
  RESOLVED_REJECT
}

enum RefundStatus {
  PENDING // đã duyệt hoàn cho người mua, CHỜ chuyển tiền (settle thủ công/qua cổng)
  SETTLED // đã chuyển tiền hoàn cho người mua
}

enum SellerApplicationStatus {
  PENDING // người mua đã gửi yêu cầu mở kênh bán, CHỜ admin duyệt
  APPROVED // admin duyệt -> nâng role lên SELLER
  REJECTED // admin từ chối
}

enum NotificationType {
  PHOTO_APPROVED // N1
  PHOTO_REJECTED // N2
  PHOTO_SOLD // N3
  PURCHASE_OK // N4
  SWAP_OFFER // N5
  SWAP_ACCEPTED // N6
  SWAP_DECLINED // N7
  REFUND_DONE // N9
  PAYOUT_RELEASED // N10
  QUOTA_LOW // N11
  SUB_ACTIVATED
  PRICE_DROP // B12: ảnh trong wishlist giảm giá
  DMCA // N8: thông báo khiếu nại DMCA
  ADMIN_ALERT // N12
  GENERIC
}

enum GrantSource {
  PURCHASE
  SWAP
  SUBSCRIPTION
}

enum SwapStatus {
  PENDING // chờ B trả lời (SW1/SW2)
  ACCEPTED // B đồng ý, 2 ảnh bị khóa, chờ xác nhận cuối (SW3/SW4)
  COMPLETED // hoàn tất, đã cấp quyền (SW5)
  DECLINED // B từ chối (SW3b)
  EXPIRED // quá 48h (SW3b)
  CANCELLED // một bên huỷ giữa chừng (SW6)
}

enum PlanType {
  FREE
  PRO
  UNLIMITED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum WalletTxType {
  ESCROW_RELEASE
  PAYOUT
  REFUND_ADJUST
  ADJUSTMENT
}

// ============================ MODELS ============================

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String? // null nếu chỉ đăng nhập bằng OAuth
  googleId     String?    @unique
  image        String? // avatar (OAuth)
  name         String
  role         Role       @default(BUYER)
  sellerTier   SellerTier @default(NEW)
  kycStatus    KycStatus  @default(NONE)

  // Ví người bán (VND)
  balanceVnd Int @default(0) // số dư có thể rút (đã giải ngân khỏi escrow)

  // Uy tín người bán
  ratingSum     Int @default(0) // tổng điểm sao nhận được
  ratingCount   Int @default(0) // số lượt đánh giá
  penaltyPoints Int @default(0) // điểm phạt (B9: hoàn tiền do lỗi người bán)

  // Thông tin nhận tiền
  payoutMethod  String? // BANK | PAYPAL
  payoutAccount String?

  isBlocked Boolean @default(false)

  // Gói subscription (AD3 / B7)
  planType     PlanType  @default(FREE)
  planRenewsAt DateTime?
  quotaUsed    Int       @default(0)
  quotaResetAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos        Photo[]
  orders        Order[]
  soldItems     OrderItem[]         @relation("ItemSeller")
  cartItems     CartItem[]
  payouts       Payout[]
  notifications Notification[]
  walletTxns    WalletTransaction[]
  escrowHolds   EscrowHold[]        @relation("SellerEscrow")
  downloads     DownloadGrant[]
  swapsSent       SwapOffer[]    @relation("SwapInitiator")
  swapsReceived   SwapOffer[]    @relation("SwapResponder")
  subscriptions   Subscription[]
  reviewsWritten  Review[]       @relation("BuyerReviews")
  reviewsReceived Review[]       @relation("SellerReviews")
  wishlist           WishlistItem[]
  dmcaClaims         DmcaClaim[]         @relation("DmcaClaimant")
  refundsReceived    RefundRecord[]      @relation("BuyerRefunds")
  sellerApplications SellerApplication[]
  misuseReports      MisuseReport[]

  @@index([role])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  photos    Photo[]
  createdAt DateTime @default(now())
}

model Photo {
  id          String      @id @default(cuid())
  seller      User        @relation(fields: [sellerId], references: [id])
  sellerId    String
  title       String
  description String      @default("")
  category    Category?   @relation(fields: [categoryId], references: [id])
  categoryId  String?
  tags        String[]    @default([])
  status      PhotoStatus @default(PENDING)

  // Khóa lưu trữ (storage keys)
  originalKey String // file gốc (vault, không lộ ra ngoài)
  previewKey  String // bản preview có watermark
  thumbKey    String // thumbnail

  width     Int @default(0)
  height    Int @default(0)
  sizeBytes Int @default(0)
  format    String @default("jpeg")

  hasModelRelease Boolean @default(false)
  allowSwap       Boolean @default(false)

  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?

  viewCount   Int @default(0)
  salesCount  Int @default(0)
  ratingSum   Int @default(0)
  ratingCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  licenses       LicenseOption[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  downloads      DownloadGrant[]
  disputes       Dispute[]
  offeredSwaps   SwapOffer[]     @relation("OfferedInSwap")
  requestedSwaps SwapOffer[]     @relation("RequestedInSwap")
  reviews        Review[]
  wishlistItems  WishlistItem[]
  dmcaClaims     DmcaClaim[]
  misuseReports  MisuseReport[]

  @@index([status])
  @@index([sellerId])
  @@index([categoryId])
}

model LicenseOption {
  id       String      @id @default(cuid())
  photo    Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId  String
  type     LicenseType
  priceVnd Int

  @@unique([photoId, type])
}

model CartItem {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  photo       Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId     String
  licenseType LicenseType
  sizeLabel   String      @default("ORIGINAL")
  priceVnd    Int
  createdAt   DateTime    @default(now())

  @@unique([userId, photoId, licenseType])
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  percentOff Int      @default(0) // 0-100
  active     Boolean  @default(true)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  orders     Order[]
}

model Order {
  id     String      @id @default(cuid())
  buyer  User        @relation(fields: [buyerId], references: [id])
  buyerId String
  status OrderStatus @default(PENDING)

  subtotalVnd   Int @default(0)
  discountVnd   Int @default(0)
  totalVnd      Int @default(0)
  platformFeeVnd Int @default(0)

  coupon   Coupon? @relation(fields: [couponId], references: [id])
  couponId String?

  paymentProvider String? // VNPAY | MOMO
  providerTxnRef  String? @unique // mã giao dịch gửi cổng (vnp_TxnRef)
  providerTxnId   String? // mã giao dịch cổng trả về
  payUrl          String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  items  OrderItem[]
  escrow EscrowHold[]

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id      String @id @default(cuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  photo   Photo  @relation(fields: [photoId], references: [id])
  photoId String
  seller  User   @relation("ItemSeller", fields: [sellerId], references: [id])
  sellerId String

  licenseType LicenseType
  sizeLabel   String      @default("ORIGINAL")

  priceVnd        Int
  platformFeeVnd  Int
  sellerEarningVnd Int

  createdAt DateTime @default(now())

  escrow   EscrowHold?
  download DownloadGrant?
  refunds  RefundRecord[]

  @@index([sellerId])
  @@index([orderId])
}

model EscrowHold {
  id          String       @id @default(cuid())
  order       Order        @relation(fields: [orderId], references: [id])
  orderId     String
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id])
  orderItemId String       @unique
  seller      User         @relation("SellerEscrow", fields: [sellerId], references: [id])
  sellerId    String
  amountVnd   Int
  status      EscrowStatus @default(HELD)
  holdUntil   DateTime
  releasedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([holdUntil])
}

model DownloadGrant {
  id            String      @id @default(cuid())
  orderItem     OrderItem?  @relation(fields: [orderItemId], references: [id])
  orderItemId   String?     @unique
  source        GrantSource @default(PURCHASE)
  swapOfferId   String? // truy vết nếu cấp qua swap
  buyer         User        @relation(fields: [buyerId], references: [id])
  buyerId       String
  photo         Photo       @relation(fields: [photoId], references: [id])
  photoId       String
  token         String      @unique
  sizeLabel     String      @default("ORIGINAL")
  licenseType   LicenseType
  expiresAt     DateTime
  maxDownloads  Int         @default(3)
  downloadCount Int         @default(0)
  certNo        String      @unique // mã chứng nhận license
  createdAt     DateTime    @default(now())

  misuseReports MisuseReport[]

  @@index([buyerId])
}

/// Báo cáo một ảnh đang bị DÙNG SAI PHẠM VI license (vd: mua "Cá nhân" nhưng chạy
/// quảng cáo thương mại). Khác Dispute/DMCA (báo về CHÍNH ảnh) — đây báo về CÁCH DÙNG
/// của người giữ license ở bên ngoài. Tra cứu qua certNo ở trang công khai `/verify`.
model MisuseReport {
  id         String       @id @default(cuid())
  photo      Photo        @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId    String
  // Grant (giấy phép) bị nghi dùng sai — gắn được nếu certNo tra ra. null nếu không rõ.
  grant      DownloadGrant? @relation(fields: [grantId], references: [id])
  grantId    String?
  certNo     String? // mã chứng nhận người báo cáo nhập (giữ lại kể cả khi không tra ra grant)
  reporter   User         @relation(fields: [reporterId], references: [id])
  reporterId String
  usageUrl   String // nơi ảnh bị dùng sai (link bằng chứng)
  detail     String       @default("")
  status     MisuseStatus @default(OPEN)
  reviewNote String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  @@index([status])
  @@index([photoId])
}

model Payout {
  id          String       @id @default(cuid())
  seller      User         @relation(fields: [sellerId], references: [id])
  sellerId    String
  amountVnd   Int
  method      String
  destination String
  status      PayoutStatus @default(REQUESTED)
  note        String?
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  @@index([sellerId])
  @@index([status])
}

model WalletTransaction {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  type           WalletTxType
  amountVnd      Int // có thể âm (payout/refund)
  balanceAfterVnd Int
  ref            String? // orderItemId / payoutId
  note           String?
  createdAt      DateTime     @default(now())

  @@index([userId])
}

model Dispute {
  id        String        @id @default(cuid())
  photo     Photo?        @relation(fields: [photoId], references: [id])
  photoId   String?
  orderItemId String?
  raisedById String
  reason    String
  detail    String        @default("")
  status    DisputeStatus @default(OPEN)
  resolution String?
  createdAt DateTime      @default(now())
  resolvedAt DateTime?

  @@index([status])
}

// Sổ ghi nợ hoàn tiền cho NGƯỜI MUA (TT5). Hệ thống không giữ ví người mua nên việc
// chi tiền hoàn thực hiện ngoài hệ thống/qua cổng — bản ghi này là nguồn ĐỐI SOÁT
// "đang nợ người mua bao nhiêu" + nơi admin đánh dấu đã chi (SETTLED).
model RefundRecord {
  id          String       @id @default(cuid())
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id])
  orderItemId String
  buyer       User         @relation("BuyerRefunds", fields: [buyerId], references: [id])
  buyerId     String
  amountVnd   Int
  percent     Int
  reason      String       @default("")
  status      RefundStatus @default(PENDING)
  note        String?
  settledAt   DateTime?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([buyerId])
  @@index([orderItemId])
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType @default(GENERIC)
  title     String
  body      String
  link      String?
  emailSent Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model SwapOffer {
  id          String     @id @default(cuid())
  initiator   User       @relation("SwapInitiator", fields: [initiatorId], references: [id])
  initiatorId String
  responder   User       @relation("SwapResponder", fields: [responderId], references: [id])
  responderId String

  offeredPhoto     Photo  @relation("OfferedInSwap", fields: [offeredPhotoId], references: [id])
  offeredPhotoId   String
  requestedPhoto   Photo  @relation("RequestedInSwap", fields: [requestedPhotoId], references: [id])
  requestedPhotoId String

  message           String     @default("")
  status            SwapStatus @default(PENDING)
  suggestedTopUpVnd Int        @default(0) // SW7: gợi ý bù tiền nếu lệch >30%

  initiatorConfirmed Boolean @default(false) // SW4 ký xác nhận cuối
  responderConfirmed Boolean @default(false)

  cancelReason String?
  expiresAt    DateTime
  respondedAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([responderId, status])
  @@index([initiatorId, status])
  @@index([status])
}

model Subscription {
  id               String             @id @default(cuid())
  user             User               @relation(fields: [userId], references: [id])
  userId           String
  plan             PlanType
  status           SubscriptionStatus @default(PENDING)
  priceVnd         Int
  autoRenew        Boolean            @default(true)
  // Cổng khởi tạo gói (BANKQR | PAYOS | VNPAY | MOMO | MOCK). Bắt buộc để xác nhận
  // thủ công ở /admin/payments CHỈ áp cho BANKQR — chống admin "đã nhận tiền" cho
  // gói do cổng tự xác nhận (chưa trả) -> kích hoạt khống (parity với Order).
  paymentProvider  String?
  providerTxnRef   String?            @unique
  startedAt        DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())

  @@index([userId])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId   String
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id])
  sellerId  String
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id])
  buyerId   String
  rating    Int // 1..5
  comment   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([photoId, buyerId]) // mỗi người mua đánh giá 1 lần / ảnh
  @@index([sellerId])
}

model DmcaClaim {
  id               String     @id @default(cuid())
  photo            Photo      @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId          String
  claimant         User       @relation("DmcaClaimant", fields: [claimantId], references: [id])
  claimantId       String
  evidence         String     @default("") // mô tả/bằng chứng sở hữu
  status           DmcaStatus @default(OPEN)
  counterStatement String? // phản biện của người bán
  deadline         DateTime // hạn 7 ngày để phản biện
  counteredAt      DateTime?
  resolvedAt       DateTime?
  resolution       String?
  createdAt        DateTime   @default(now())

  @@index([status])
  @@index([photoId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId    String
  priceAtAdd Int      @default(0) // giá thấp nhất khi thêm — dùng để phát hiện giảm giá
  createdAt  DateTime @default(now())

  @@unique([userId, photoId])
  @@index([photoId])
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Yêu cầu mở kênh bán (S1): người mua gửi -> admin DUYỆT mới nâng role lên SELLER.
// Trong lúc PENDING người dùng vẫn là BUYER (không thấy chức năng bán).
model SellerApplication {
  id         String                  @id @default(cuid())
  user       User                    @relation(fields: [userId], references: [id])
  userId     String
  status     SellerApplicationStatus @default(PENDING)
  pitch      String                  @default("") // lý do/giới thiệu của người đăng ký
  reviewNote String? // phản hồi của admin khi duyệt/từ chối
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime                @default(now())

  @@index([status])
  @@index([userId])
}
