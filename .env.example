# ============================================================
# PICSEO — Biến môi trường (sao chép sang .env và điền giá trị)
# ============================================================

# --- App ---
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Khóa bí mật ký JWT phiên đăng nhập (đổi thành chuỗi ngẫu nhiên dài)
AUTH_SECRET="doi-thanh-chuoi-ngau-nhien-rat-dai-bi-mat"

# Khóa bí mật ký link tải file (signed download token)
DOWNLOAD_SECRET="doi-thanh-chuoi-bi-mat-khac-cho-link-tai"

# Khóa bí mật bảo vệ endpoint cron (gọi /api/cron/* phải kèm header này)
CRON_SECRET="chuoi-bi-mat-cho-cron"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:123456@localhost:5432/picseo?schema=public"

# --- Storage ---
# local  -> lưu file vào thư mục ./storage (mặc định, dễ chạy thử)
# s3     -> lưu vào S3 / MinIO (điền các biến S3_* bên dưới)
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR="./storage"

S3_ENDPOINT="http://localhost:9000"        # MinIO endpoint, để trống nếu dùng AWS S3
S3_REGION="us-east-1"
S3_BUCKET="picseo"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"                  # true cho MinIO

# --- Email (SMTP) ---
# Để trống -> dev mode: email được in ra console (không gửi thật)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Picseo <no-reply@picseo.local>"

# --- VNPay (sandbox) ---
# Đăng ký merchant sandbox tại https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_PAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/api/payment/vnpay/callback"
VNPAY_IPN_URL="http://localhost:3000/api/payment/vnpay/ipn"

# --- MoMo (sandbox) ---
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"

# --- PayOS (VietQR) — phương án phụ (cần xác minh doanh nghiệp) ---
# Đăng ký & lấy khóa tại https://my.payos.vn (mục Kênh thanh toán -> Thông tin xác thực).
# Webhook URL khai báo trên dashboard PayOS: <APP_URL>/api/payment/payos
# (local cần URL public, ví dụ ngrok). Return/Cancel URL do code tự gắn.
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
PAYOS_CREATE_URL="https://api-merchant.payos.vn/v2/payment-requests"

# --- Chuyển khoản QR ngân hàng — CỔNG CHÍNH (xác nhận THỦ CÔNG) ---
# Người mua quét QR chuyển khoản; admin đối chiếu biến động số dư rồi bấm xác nhận
# tại /admin/payments. Không cần cổng/hợp đồng — chỉ cần tài khoản ngân hàng của bạn.
#
# QR hiển thị theo 1 trong 2 cách:
#   (1) Ảnh QR tĩnh của tài khoản: dán URL vào BANK_QR_IMAGE (lấy từ app NH, hoặc đặt
#       file vào thư mục /public rồi điền "/qr.png"). Người mua tự nhập số tiền + nội dung.
#   (2) VietQR động: để trống BANK_QR_IMAGE, điền BANK_ID + BANK_ACCOUNT để hệ thống dựng
#       QR qua vietqr.io đã nhúng sẵn số tiền + nội dung (tiện hơn cho người mua).
# Dù cách nào, người mua cần ghi ĐÚNG nội dung "PIC..." + ĐÚNG số tiền để admin đối chiếu.
BANK_ID="MOMO"                 # mã NH cho VietQR động (vietqr.io): MB, VCB, ACB, TCB, BIDV...
BANK_ACCOUNT="PSP2617111800000108"              # số tài khoản nhận tiền
BANK_ACCOUNT_NAME="LE VAN TUAN"         # tên chủ tài khoản (hiển thị cho người mua)
BANK_QR_IMAGE="/qr.png"             # URL/đường dẫn ảnh QR tĩnh (ưu tiên nếu có)
BANK_QR_TEMPLATE="compact2"  # mẫu QR động vietqr.io: compact2 | compact | qr_only | print
# Tuỳ chọn nâng cao: bật tự xác nhận qua dịch vụ giám sát số dư (SePay/Casso) thay vì thủ
# công — đặt key trùng dashboard, trỏ webhook về <APP_URL>/api/payment/sepay.
SEPAY_API_KEY=""

# --- Đăng nhập Google (OAuth 2.0) ---
# Tạo OAuth Client (Web) tại https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_URL>/api/auth/google/callback
# Để trống -> ẩn nút đăng nhập Google.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Quy tắc nghiệp vụ ---
ESCROW_HOLD_DAYS="7"            # số ngày giữ tiền trong escrow
DOWNLOAD_LINK_HOURS="24"        # link tải hết hạn sau bao nhiêu giờ
MAX_DOWNLOADS="3"               # số lần tải tối đa mỗi lần mua
MIN_PAYOUT_VND="500000"         # ngưỡng rút tiền tối thiểu (~$20)
